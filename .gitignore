# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage
/playwright-report
/test-results
/blob-report

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.idea/
# clerk configuration (can include secrets)
/.clerk/


# cursor
.cursorrules
/memory-bank

# Sentry Config File
.env.sentry-build-plugin

# Additional ignores

# IDE/project files
.vscode/
*.suo
*.ntvs*
.vs/

# macOS
.DS_Store

# build artifacts
/dist
/out
.cache

# environment files (local overrides)
.env.local
.env.development.local
.env.test.local
.env.production.local

# package manager logs
pnpm-debug.log*

# optional lock files generated by tools
/.parcel-cache
.github/
