{
  "name": "Quality-Hub API (Fullstack Services)",
  "dockerComposeFile": "../../../../.devcontainer/docker-compose.yml",
  "service": "app",
  "runServices": ["app", "db", "redis", "gitlab"],
  "workspaceFolder": "/workspace/src/app/api",
  "remoteUser": "root",
  "containerUser": "root",
  "updateRemoteUserUID": false,

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker",
        "redhat.vscode-yaml"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspace/src/app/api/.venv/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["src/app/api/tests"],
        "python.analysis.extraPaths": ["/workspace/src/app/api/src"]
      }
    }
  },

  "forwardPorts": [3000, 8000, 8929, 5432, 6379],
  "portsAttributes": {
    "3000": {
      "label": "Next.js Web",
      "onAutoForward": "notify"
    },
    "8000": {
      "label": "FastAPI",
      "onAutoForward": "notify"
    },
    "8929": {
      "label": "GitLab Demo",
      "onAutoForward": "notify"
    },
    "5432": {
      "label": "PostgreSQL",
      "onAutoForward": "silent"
    },
    "6379": {
      "label": "Redis",
      "onAutoForward": "silent"
    }
  },

  "remoteEnv": {
    "PYTHONPATH": "/workspace/src/app/api/src",
    "COREPACK_HOME": "/root/.local/share/corepack"
  },

  "postCreateCommand": "bash /workspace/.devcontainer/post-create.sh",
  "postStartCommand": "bash /workspace/.devcontainer/post-start.sh"
}
